{
  "buildCommand": null,
  "outputDirectory": "site",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/((?!assets/|robots\\.txt|sitemap\\.xml|styles\\.css|index\\.html).*)", "destination": "/index.html" }
  ]
}
