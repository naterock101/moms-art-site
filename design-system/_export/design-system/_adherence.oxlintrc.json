{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/filters/**",
              "components/gallery/**",
              "components/navigation/**",
              "components/ui/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Cormorant|DM Sans))/i]",
        "message": "Font not provided by the design system. Available: Cormorant, DM Sans."
      },
      {
        "selector": "JSXOpeningElement[name.name='ArtworkCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|alt|title|medium|year|aspectRatio|onClick|key|ref|className|style|children)$/]",
        "message": "<ArtworkCard> doesn't accept that prop. Declared props: src, alt, title, medium, year, aspectRatio, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|onClick|href|disabled|type|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, onClick, href, disabled, type."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FilterBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:primaryFilter|onPrimaryChange|secondaryFilters|activeTags|onTagToggle|key|ref|className|style|children)$/]",
        "message": "<FilterBar> doesn't accept that prop. Declared props: primaryFilter, onPrimaryChange, secondaryFilters, activeTags, onTagToggle."
      },
      {
        "selector": "JSXOpeningElement[name.name='FilterBar'] > JSXAttribute[name.name='primaryFilter'] > Literal[value!=/^(?:all|painting|sculpture)$/]",
        "message": "<FilterBar> primaryFilter must be one of 'all' | 'painting' | 'sculpture'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FilterChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|active|onClick|key|ref|className|style|children)$/]",
        "message": "<FilterChip> doesn't accept that prop. Declared props: label, active, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='GalleryGrid'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|columns|gap|key|ref|className|style|children)$/]",
        "message": "<GalleryGrid> doesn't accept that prop. Declared props: children, columns, gap."
      },
      {
        "selector": "JSXOpeningElement[name.name='Header'] > JSXAttribute > JSXIdentifier[name!=/^(?:activePage|onNavigate|key|ref|className|style|children)$/]",
        "message": "<Header> doesn't accept that prop. Declared props: activePage, onNavigate."
      },
      {
        "selector": "JSXOpeningElement[name.name='Header'] > JSXAttribute[name.name='activePage'] > Literal[value!=/^(?:gallery|painting|sculpture|about|contact)$/]",
        "message": "<Header> activePage must be one of 'gallery' | 'painting' | 'sculpture' | 'about' | 'contact'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|category|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: label, category."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "ArtworkCard": {
        "replaces": []
      },
      "Button": {
        "replaces": []
      },
      "FilterBar": {
